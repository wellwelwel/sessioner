{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "allowUnusedLabels": false,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "declaration": true,
    "declarationDir": "./lib",
    "outDir": "./lib",
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"]
}
